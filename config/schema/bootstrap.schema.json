{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mauiday.net/schemas/bootstrap.schema.json",
  "title": "MAUI Day app bootstrap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "activeEventId",
    "events"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "activeEventId": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "configUrl",
          "bundledConfigAsset"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "configUrl": {
            "type": "string",
            "format": "uri"
          },
          "bundledConfigAsset": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
