<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net11.0-android;net11.0-ios</TargetFrameworks>
		<!-- Allow CI to build a single platform without the override propagating
		     to referenced projects (as a global TargetFrameworks property would). -->
		<TargetFrameworks Condition="'$(CIBuildTfm)' != ''">$(CIBuildTfm)</TargetFrameworks>

		<OutputType>Exe</OutputType>
		<RootNamespace>MauiDay.App</RootNamespace>
		<UseMaui>true</UseMaui>
		<SingleProject>true</SingleProject>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!-- Required for XAML C# Expressions (source-generated) in .NET 11 Preview 6 -->
		<EnablePreviewFeatures>true</EnablePreviewFeatures>


		<!-- Display name -->
		<ApplicationTitle>MAUI Day</ApplicationTitle>

		<!-- App Identifier -->
		<ApplicationId>net.mauiday.companion</ApplicationId>

		<!-- Versions -->
		<ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
		<ApplicationVersion>1</ApplicationVersion>

		<!-- To develop, package, and publish an app to the Microsoft Store, see: https://aka.ms/MauiTemplateUnpackaged -->
		<WindowsPackageType>None</WindowsPackageType>

		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">17.0</SupportedOSPlatformVersion>
		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">24.0</SupportedOSPlatformVersion>
		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</SupportedOSPlatformVersion>
		<TargetPlatformMinVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</TargetPlatformMinVersion>
	</PropertyGroup>

	<ItemGroup>
		<!-- App Icon -->
		<MauiIcon Include="Resources\AppIcon\appicon.svg" Color="#0B1D51" />

		<!-- Splash Screen -->
		<MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#0B1D51" BaseSize="256,62" />

		<!-- Images -->
		<MauiImage Include="Resources\Images\*" />
		<!-- Custom Fonts -->
		<MauiFont Include="Resources\Fonts\*.ttf" />

		<!-- Raw Assets (also remove the "Resources\Raw" prefix) -->
		<MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="IconFont.Maui.FluentIcons" Version="1.1.1" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
		<PackageReference Include="Microsoft.Extensions.Http" Version="11.0.0-preview.6.*" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="11.0.0-preview.6.*" />
		<PackageReference Include="Microsoft.Maui.DevFlow.Agent"
		                  Version="0.1.0-preview.12.26358.3"
		                  Condition="'$(Configuration)' == 'Debug'" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\MauiDay.Core\MauiDay.Core.csproj" />
	</ItemGroup>

	<ItemGroup>
		<MauiAsset Include="..\..\config\**\*.json"
		           LogicalName="config/%(RecursiveDir)%(Filename)%(Extension)" />
		<MauiAsset Include="Resources\Fonts\Licenses\*.txt"
		           LogicalName="licenses/fonts/%(Filename)%(Extension)" />
	</ItemGroup>

</Project>
