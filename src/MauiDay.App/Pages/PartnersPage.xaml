<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiDay.App.Pages.PartnersPage"
    x:Name="Root"
    x:DataType="vm:PartnersViewModel"
    AutomationId="PartnersPage"
    Title="Partners"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:MauiDay.App.ViewModels"
    xmlns:vm="clr-namespace:MauiDay.App.ViewModels">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource DetailPagePadding}" Spacing="24">
            <VerticalStackLayout Spacing="6">
                <Label Style="{StaticResource PageTitleLabel}" Text="Built with community" />
                <Label
                    Style="{StaticResource SecondaryLabel}"
                    Text="MAUI Day is possible thanks to these sponsors and supporters." />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding HasSponsors}" Spacing="12">
                <Label Style="{StaticResource SectionTitleLabel}" Text="Sponsor" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sponsors}" Spacing="12">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:PartnerCardModel">
                            <Border
                                AutomationId="{Binding Name, StringFormat='Partner_{0}'}"
                                Padding="20"
                                BackgroundColor="{StaticResource White}"
                                SemanticProperties.Description="{Binding Name}"
                                SemanticProperties.Hint="Opens the partner website"
                                Stroke="{StaticResource DividerLight}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.OpenPartnerCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="8">
                                    <Image
                                        Aspect="AspectFit"
                                        HeightRequest="64"
                                        SemanticProperties.Description=""
                                        Source="{Binding LogoUrl}" />
                                    <Label
                                        FontFamily="PoppinsMedium"
                                        FontSize="14"
                                        HorizontalTextAlignment="Center"
                                        Text="{Binding Name}"
                                        TextColor="{StaticResource BrandNavy}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding HasSupporters}" Spacing="12">
                <Label Style="{StaticResource SectionTitleLabel}" Text="Supporters" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Supporters}" Spacing="12">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:PartnerCardModel">
                            <Border
                                AutomationId="{Binding Name, StringFormat='Partner_{0}'}"
                                Padding="18"
                                BackgroundColor="{StaticResource White}"
                                SemanticProperties.Description="{Binding Name}"
                                SemanticProperties.Hint="Opens the partner website"
                                Stroke="{StaticResource DividerLight}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.OpenPartnerCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="8">
                                    <Image
                                        Aspect="AspectFit"
                                        HeightRequest="52"
                                        SemanticProperties.Description=""
                                        Source="{Binding LogoUrl}" />
                                    <Label
                                        FontFamily="PoppinsMedium"
                                        FontSize="13"
                                        HorizontalTextAlignment="Center"
                                        Text="{Binding Name}"
                                        TextColor="{StaticResource BrandNavy}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Label
                HorizontalTextAlignment="Center"
                IsVisible="{Binding HasStatusMessage}"
                Style="{StaticResource CaptionLabel}"
                Text="{Binding StatusMessage}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
